{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ReverseProxy": {
    "Routes": {
      "identity-route": {
        "ClusterId": "identity",
        "Match": {
          "Path": "/api/auth/{**catch-all}"
        },
        "Transforms": [
          { "PathPattern": "/api/auth/{**catch-all}" }
        ]
      },
      "ticket-route": {
        "ClusterId": "ticket",
        "Match": {
          "Path": "/api/tickets/{**catch-all}"
        },
        "Transforms": [
          { "PathPattern": "/api/tickets/{**catch-all}" }
        ]
      },
      "identity-swagger": {
        "ClusterId": "identity",
        "Match": {
          "Path": "/identity/swagger/{**catch-all}"
        },
        "Transforms": [
          { "PathPattern": "/swagger/{**catch-all}" }
        ]
      },
      "ticket-swagger": {
        "ClusterId": "ticket",
        "Match": {
          "Path": "/ticket/swagger/{**catch-all}"
        },
        "Transforms": [
          { "PathPattern": "/swagger/{**catch-all}" }
        ]
      }
    },
    "Clusters": {
      "identity": {
        "Destinations": {
          "destination1": {
            "Address": "http://identity-service:8080/"
          }
        }
      },
      "ticket": {
        "Destinations": {
          "destination1": {
            "Address": "http://ticket-service:8080/"
          }
        }
      }
    }
  }
}
